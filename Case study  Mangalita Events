<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Case Study: Mangalita Events — Napwave Digital</title>
  <meta name="description" content="How Napwave Digital took Mangalita Events from invisible on Google to #1 in Kitwe in under 8 weeks." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Syne:wght@700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black:   #0A0A0F;
      --surface: #111118;
      --card:    #18181F;
      --border:  #2A2A35;
      --accent:  #6C63FF;
      --accent2: #A78BFA;
      --text:    #E8E8F0;
      --muted:   #7A7A90;
      --success: #34D399;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--black);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    /* ── NAV ── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(10,10,15,0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: 0 24px;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-logo {
      font-family: 'Syne', sans-serif;
      font-size: 18px;
      font-weight: 800;
      color: var(--text);
      text-decoration: none;
      letter-spacing: -0.3px;
    }
    .nav-logo span { color: var(--accent); }
    .nav-back {
      font-size: 13px;
      color: var(--muted);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: color 0.2s;
    }
    .nav-back:hover { color: var(--text); }

    /* ── HERO ── */
    .hero {
      max-width: 760px;
      margin: 0 auto;
      padding: 80px 24px 64px;
    }
    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 1.2px;
      text-transform: uppercase;
      color: var(--accent2);
      margin-bottom: 24px;
    }
    .eyebrow::before {
      content: '';
      display: block;
      width: 20px;
      height: 2px;
      background: var(--accent2);
    }
    h1 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(32px, 6vw, 52px);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -1.5px;
      color: var(--text);
      margin-bottom: 20px;
    }
    h1 em {
      font-style: normal;
      color: var(--accent2);
    }
    .hero-sub {
      font-size: 17px;
      color: var(--muted);
      max-width: 560px;
      line-height: 1.65;
    }

    /* ── RESULT STRIP ── */
    .result-strip {
      background: var(--card);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 40px 24px;
      margin: 0;
    }
    .result-strip-inner {
      max-width: 760px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
    }
    .stat {
      padding: 0 32px 0 0;
      border-right: 1px solid var(--border);
    }
    .stat:last-child { border-right: none; padding-left: 32px; padding-right: 0; }
    .stat:nth-child(2) { padding-left: 32px; }
    .stat-num {
      font-family: 'Syne', sans-serif;
      font-size: clamp(36px, 6vw, 52px);
      font-weight: 800;
      line-height: 1;
      color: var(--success);
      letter-spacing: -2px;
    }
    .stat-label {
      font-size: 13px;
      color: var(--muted);
      margin-top: 6px;
      line-height: 1.4;
    }

    /* ── BODY CONTENT ── */
    .content {
      max-width: 760px;
      margin: 0 auto;
      padding: 64px 24px;
    }
    .content section { margin-bottom: 64px; }

    h2 {
      font-family: 'Syne', sans-serif;
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.5px;
      color: var(--text);
      margin-bottom: 20px;
    }
    p { color: #B0B0C8; margin-bottom: 16px; }
    p:last-child { margin-bottom: 0; }

    /* ── BEFORE / AFTER ── */
    .ba-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-top: 24px;
    }
    .ba-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 24px;
    }
    .ba-card.before { border-top: 3px solid #EF4444; }
    .ba-card.after  { border-top: 3px solid var(--success); }
    .ba-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-bottom: 16px;
    }
    .ba-card.before .ba-label { color: #EF4444; }
    .ba-card.after  .ba-label { color: var(--success); }
    .ba-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      margin-bottom: 12px;
      font-size: 14px;
      color: var(--muted);
      line-height: 1.5;
    }
    .ba-item:last-child { margin-bottom: 0; }
    .ba-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      margin-top: 6px;
      flex-shrink: 0;
    }
    .before .ba-dot { background: #EF4444; }
    .after  .ba-dot { background: var(--success); }

    /* ── WHAT WE DID ── */
    .steps { margin-top: 24px; }
    .step {
      display: flex;
      gap: 20px;
      margin-bottom: 28px;
      align-items: flex-start;
    }
    .step-num {
      font-family: 'Syne', sans-serif;
      font-size: 12px;
      font-weight: 800;
      color: var(--accent2);
      background: rgba(108,99,255,0.12);
      border: 1px solid rgba(108,99,255,0.25);
      border-radius: 6px;
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .step-body h3 {
      font-size: 15px;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 4px;
    }
    .step-body p {
      font-size: 14px;
      margin-bottom: 0;
    }

    /* ── CHART ── */
    .chart-block {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 28px 24px 20px;
      margin-top: 24px;
    }
    .chart-title {
      font-size: 13px;
      font-weight: 600;
      color: var(--muted);
      margin-bottom: 20px;
    }
    .bar-chart {
      display: flex;
      align-items: flex-end;
      gap: 10px;
      height: 120px;
    }
    .bar-wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      flex: 1;
      height: 100%;
      justify-content: flex-end;
      gap: 6px;
    }
    .bar {
      width: 100%;
      border-radius: 4px 4px 0 0;
      background: var(--accent);
      opacity: 0.7;
      transition: opacity 0.2s;
    }
    .bar.highlight { opacity: 1; background: var(--success); }
    .bar-month {
      font-size: 11px;
      color: var(--muted);
    }
    .bar-val {
      font-size: 11px;
      font-weight: 600;
      color: var(--text);
    }

    /* ── QUOTE ── */
    .quote-block {
      border-left: 3px solid var(--accent2);
      padding: 20px 24px;
      background: var(--card);
      border-radius: 0 10px 10px 0;
      margin-top: 24px;
    }
    .quote-text {
      font-size: 17px;
      font-style: italic;
      color: var(--text);
      line-height: 1.6;
      margin-bottom: 12px;
    }
    .quote-attr {
      font-size: 13px;
      color: var(--muted);
    }

    /* ── CTA ── */
    .cta-section {
      background: linear-gradient(135deg, rgba(108,99,255,0.12) 0%, rgba(167,139,250,0.06) 100%);
      border: 1px solid rgba(108,99,255,0.25);
      border-radius: 16px;
      padding: 48px 40px;
      text-align: center;
      margin-top: 32px;
    }
    .cta-section h2 { margin-bottom: 12px; }
    .cta-section p {
      font-size: 16px;
      max-width: 440px;
      margin: 0 auto 28px;
    }
    .btn {
      display: inline-block;
      background: var(--accent);
      color: #fff;
      font-size: 15px;
      font-weight: 600;
      padding: 14px 32px;
      border-radius: 8px;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s;
    }
    .btn:hover { background: #5a52e0; transform: translateY(-1px); }

    /* ── FOOTER ── */
    footer {
      border-top: 1px solid var(--border);
      padding: 28px 24px;
      text-align: center;
      font-size: 13px;
      color: var(--muted);
    }
    footer a { color: var(--muted); text-decoration: none; }
    footer a:hover { color: var(--text); }

    /* ── RESPONSIVE ── */
    @media (max-width: 600px) {
      .result-strip-inner {
        grid-template-columns: 1fr;
        gap: 28px;
      }
      .stat { border-right: none; padding: 0; }
      .stat:nth-child(2) { padding: 0; }
      .ba-grid { grid-template-columns: 1fr; }
      .cta-section { padding: 36px 24px; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav>
    <a class="nav-logo" href="/">Napwave<span>.</span></a>
    <a class="nav-back" href="/#case-studies">← Back to case studies</a>
  </nav>

  <!-- HERO -->
  <header class="hero">
    <div class="eyebrow">Case Study · Kitwe, Zambia</div>
    <h1>From invisible on Google<br/>to <em>#1 in Kitwe</em><br/>in under 8 weeks.</h1>
    <p class="hero-sub">How Napwave Digital helped Mangalita Events — a local wedding and events business — go from zero Google presence to ranking first for their highest-value search term.</p>
  </header>

  <!-- STATS -->
  <div class="result-strip">
    <div class="result-strip-inner">
      <div class="stat">
        <div class="stat-num">#1</div>
        <div class="stat-label">Ranking for "Event planner in Kitwe"</div>
      </div>
      <div class="stat">
        <div class="stat-num">261</div>
        <div class="stat-label">Google Business Profile views generated</div>
      </div>
      <div class="stat">
        <div class="stat-num">179</div>
        <div class="stat-label">Profile interactions in first 6 months</div>
      </div>
    </div>
  </div>

  <!-- BODY -->
  <main class="content">

    <!-- THE PROBLEM -->
    <section>
      <h2>The problem</h2>
      <p>When Mangalita Events came to Napwave Digital in May 2026, they had a real business — weddings, corporate events, and private functions in Kitwe — but no Google presence to show for it. They weren't on page one, page two, or anywhere a prospective client would find them.</p>
      <p>Their Google Business Profile existed but was effectively invisible: incomplete information, no optimised description, and no strategy for local search. Every potential client searching "event planner in Kitwe" was finding competitors instead.</p>

      <div class="ba-grid">
        <div class="ba-card before">
          <div class="ba-label">Before</div>
          <div class="ba-item"><div class="ba-dot"></div>Not ranking on any known page for target keywords</div>
          <div class="ba-item"><div class="ba-dot"></div>Google Business Profile incomplete and unoptimised</div>
          <div class="ba-item"><div class="ba-dot"></div>Near-zero profile views and interactions per month</div>
          <div class="ba-item"><div class="ba-dot"></div>No review strategy or engagement on GBP</div>
        </div>
        <div class="ba-card after">
          <div class="ba-label">After</div>
          <div class="ba-item"><div class="ba-dot"></div>Ranking #1 for "Event planner in Kitwe"</div>
          <div class="ba-item"><div class="ba-dot"></div>Fully optimised GBP with outcomes-focused copy</div>
          <div class="ba-item"><div class="ba-dot"></div>261 profile views, 179 interactions generated</div>
          <div class="ba-item"><div class="ba-dot"></div>Monthly interactions trending upward to 50+/month</div>
        </div>
      </div>
    </section>

    <!-- WHAT WE DID -->
    <section>
      <h2>What we did</h2>
      <div class="steps">
        <div class="step">
          <div class="step-num">1</div>
          <div class="step-body">
            <h3>Google Business Profile audit &amp; rebuild</h3>
            <p>We audited every field of the GBP — business category, service areas, hours, description, and photo coverage — and rebuilt it from scratch with keyword-rich, conversion-focused copy designed to match exactly what Kitwe-based clients search for.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <div class="step-body">
            <h3>Local keyword targeting</h3>
            <p>We identified the highest-intent local search terms for Mangalita's services and aligned the GBP description, service listings, and posts to those exact queries — prioritising "event planner in Kitwe" as the primary target keyword.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">3</div>
          <div class="step-body">
            <h3>Review strategy &amp; reputation management</h3>
            <p>We drafted professional, keyword-aware responses to incoming client reviews and implemented a review request process to grow social proof — a key local ranking signal Google rewards.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">4</div>
          <div class="step-body">
            <h3>Ongoing optimisation on retainer</h3>
            <p>Mangalita Events is on a month-to-month retainer with Napwave Digital. We monitor GBP performance weekly, update posts, and continue building local authority through consistent on-page and off-page work.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- RESULTS -->
    <section>
      <h2>The results</h2>
      <p>Within weeks of starting work, Mangalita Events moved from an untracked, invisible position to ranking first on Google for their primary keyword. The GBP performance data tells the story clearly: interactions went from near zero in January to a consistent 40–50+ per month by March, and have held strong through June 2026.</p>

      <div class="chart-block">
        <div class="chart-title">Monthly GBP Interactions — Jan to Jun 2026</div>
        <div class="bar-chart">
          <div class="bar-wrap">
            <div class="bar-val">~5</div>
            <div class="bar" style="height:10%"></div>
            <div class="bar-month">Jan</div>
          </div>
          <div class="bar-wrap">
            <div class="bar-val">~15</div>
            <div class="bar" style="height:25%"></div>
            <div class="bar-month">Feb</div>
          </div>
          <div class="bar-wrap">
            <div class="bar-val">~50</div>
            <div class="bar highlight" style="height:100%"></div>
            <div class="bar-month">Mar</div>
          </div>
          <div class="bar-wrap">
            <div class="bar-val">~40</div>
            <div class="bar highlight" style="height:82%"></div>
            <div class="bar-month">Apr</div>
          </div>
          <div class="bar-wrap">
            <div class="bar-val">~30</div>
            <div class="bar" style="height:60%"></div>
            <div class="bar-month">May</div>
          </div>
          <div class="bar-wrap">
            <div class="bar-val">~45</div>
            <div class="bar highlight" style="height:92%"></div>
            <div class="bar-month">Jun</div>
          </div>
        </div>
      </div>

      <div class="quote-block" style="margin-top:32px;">
        <div class="quote-text">"We went from people not finding us at all on Google, to ranking first in Kitwe. The difference in enquiries has been noticeable."</div>
        <div class="quote-attr">— Client, Mangalita Events, Kitwe</div>
      </div>
    </section>

    <!-- CTA -->
    <div class="cta-section">
      <h2>Want results like this?</h2>
      <p>We help wedding planners and event businesses get found on Google — no long contracts, no guesswork.</p>
      <a class="btn" href="/#contact">Book a free clarity call</a>
    </div>

  </main>

  <footer>
    <p>&copy; 2026 Napwave Digital &nbsp;·&nbsp; <a href="/">napwavedigital.github.io</a></p>
  </footer>

</body>
</html>
